{
  "schema": "lattice.plugin.manifest.v2",
  "id": "latticenet.wireguard",
  "name": "WireGuard (VPN networks)",
  "type": "system",
  "capabilities": [
    "node:read",
    "network:plan",
    "network:apply",
    "task:run"
  ],
  "version": "0.1.0-alpha.6",
  "publisher": "latticenet",
  "signature_ed25519": "RygmT0dtjg+tFCN5XstXFaLJLo2ugnY2Rh4gojtM2fxJydiZyzeGICEtrQJUZrb17VTSuBTX66+3jeEFVShwDg==",
  "bundle": {
    "format": "tar+gzip",
    "digest_sha256": "065912c3c92df93e0ac7d6cce4fd3f2ba2839b4f9b840efc7ecb88173c3ce147"
  },
  "runtime": {
    "protocol": "stdio-json-v1",
    "entrypoints": {
      "linux/amd64": "bin/linux-amd64/plugin",
      "linux/arm64": "bin/linux-arm64/plugin"
    }
  },
  "ui_runtime": {
    "mode": "sandbox",
    "entrypoint": "ui/index.html",
    "bridge_version": "1"
  },
  "compatibility": {
    "server": "\u003e=0.2.1",
    "dashboard_host": "\u003e=1",
    "runtime_protocol": "\u003e=1"
  },
  "ui": {
    "nav": [
      {
        "section": "extensions",
        "section_title": "Extensions",
        "title": "WireGuard",
        "route": "networks",
        "icon": "Spline",
        "scopes": [
          "node:read"
        ]
      }
    ],
    "views": [
      {
        "route": "networks",
        "title": "WireGuard Networks",
        "kind": "sandbox"
      }
    ]
  },
  "interfaces": [
    {
      "service": "latticenet.wireguard/networks",
      "methods": [
        {
          "name": "overview",
          "effect": "read",
          "scopes": [
            "node:read"
          ]
        },
        {
          "name": "plan",
          "effect": "plan",
          "scopes": [
            "network:plan"
          ]
        }
      ]
    }
  ]
}
